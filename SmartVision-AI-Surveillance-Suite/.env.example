SMARTVISION_ENV=dev
SMARTVISION_API_KEY=dev-token
DATABASE_URL=sqlite:///data/smartvision.db
# For MongoDB Atlas metadata storage, use:
# DATABASE_URL=mongodb+srv://<user>:<password>@<cluster-host>/
MONGODB_DATABASE=smartvision_ai_surveillance_suite
AI_DEVICE=auto
AI_HALF_PRECISION=true

# Optional notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ENABLE_SOUND_ALARMS=false
